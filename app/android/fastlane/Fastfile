default_platform(:android)

AAB = File.expand_path("../../build/app/outputs/bundle/release/app-release.aab", __dir__)
PKG = "dev.leentj.trotcard"

platform :android do
  desc "Upload AAB to the internal testing track as a draft"
  lane :internal do
    upload_to_play_store(
      track: "internal",
      aab: AAB,
      json_key: "fastlane/play-store-key.json",
      package_name: PKG,
      release_status: "draft",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )
  end

  desc "Upload AAB to the closed testing (alpha) track as a draft"
  lane :closed do
    upload_to_play_store(
      track: "alpha",
      aab: AAB,
      json_key: "fastlane/play-store-key.json",
      package_name: PKG,
      release_status: "draft",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )
  end

  desc "Promote the internal track build to production"
  lane :production do
    upload_to_play_store(
      track: "internal",
      track_promote_to: "production",
      json_key: "fastlane/play-store-key.json",
      package_name: PKG,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )
  end
end
